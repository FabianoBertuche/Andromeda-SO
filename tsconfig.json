{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "baseUrl": ".",
        "paths": {
            "@andromeda/core": [
                "./packages/core/src/index.ts"
            ]
        },
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "dist",
        "declaration": true
    },
    "include": [
        "packages/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "**/dist",
        "**/*.test.ts",
        "**/*.spec.ts"
    ]
}
