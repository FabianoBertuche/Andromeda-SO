  "description": "Uso para pesquisa e coleta controlada na web.",
  "version": 1,
  "isSystem": true,
  "mode": "process",
  "riskLevel": "moderate",
  "config": {
    "enabled": true,
    "mode": "process",
    "filesystem": {
