# ============================================
# Production Environment Template
# LEI 13: Isolamento de Ambientes
# ============================================
# Copy this file to .env.production and fill in the values
# NEVER commit this file with real secrets

# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV=production
APP_ENV=production
PORT=5000

# ============================================
# DATABASE (Production)
# ============================================
# Use separate database per environment
PROD_DATABASE_URL=postgresql://user:password@prod-db.internal:5432/andromeda_prod

# ============================================
# REDIS (Production)
# ============================================
PROD_REDIS_URL=redis://prod-redis.internal:6379

# ============================================
# AUTHENTICATION - LEI 05: Session Hardening
# ============================================
# MUST be at least 32 characters
# Generate with: openssl rand -base64 32
PROD_JWT_SECRET=CHANGE_ME_at_least_32_characters_long

# MUST be 12 or higher (LEI 07)
PROD_BCRYPT_ROUNDS=12

# Access tokens should be short-lived
PROD_JWT_ACCESS_EXPIRES=15m
PROD_JWT_REFRESH_EXPIRES=30d

# ============================================
# ENCRYPTION - LEI 04: Secrets Vault
# ============================================
# REQUIRED in production
# Generate with: openssl rand -base64 32 | tr '+/' '-_'
ENCRYPTION_KEY=CHANGE_ME_base64_url_safe_key

# ============================================
# RATE LIMITING (Production values)
# ============================================
PROD_RATE_LIMIT_WINDOW_MS=60000
PROD_RATE_LIMIT_MAX=50
PROD_RATE_LIMIT_AUTH_MAX=5

# ============================================
# SERVICES (Production URLs)
# ============================================
PROD_COGNITIVE_PYTHON_URL=https://cognitive.internal:8008
PROD_COGNITIVE_PYTHON_TOKEN=CHANGE_ME_secure_token

# ============================================
# SECURITY WARNINGS
# ============================================
# - Never use 'live' keys in development/test
# - Never commit secrets to version control
# - Use environment-specific database
# - Enable TLS in production (NODE_TLS_REJECT_UNAUTHORIZED=1)