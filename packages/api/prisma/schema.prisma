generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SandboxMode {
  none
  process
  container
  remote
}

enum RiskLevel {
  low
  moderate
  high
  critical
}

enum SandboxExecutionStatus {
  queued
  awaiting_approval
  provisioning
  running
  completed
  failed
  timed_out
  blocked_by_policy
  cancelled
}

enum ApprovalStatus {
  pending
  approved
  rejected
}

enum MemoryType {
  session
  episodic
  semantic
}

enum MemoryScopeType {
  session
  task
  agent
  project
  user
  team
}

enum MemoryStatus {
  active
  archived
  invalidated
  deleted
}

enum MemoryRetentionMode {
  ttl
  session
  task
  persistent
}

enum KnowledgeScopeType {
  agent
  team
  project
  shared
}

enum KnowledgeSourceType {
  upload
  manual
  vault
}

enum KnowledgeStatus {
  pending
  processing
  completed
  failed
  archived
}

model SandboxProfile {
  id          String      @id
  name        String
  description String
  version     Int
  isSystem    Boolean
  mode        SandboxMode
  riskLevel   RiskLevel
  config      Json
  createdAt   DateTime
  updatedAt   DateTime

  agentConfigs AgentSandboxConfig[]

  @@map("sandbox_profiles")
}

model AgentSandboxConfig {
  agentId      String   @id
  enabled      Boolean
  profileId    String?
  overrides    Json
  enforcement  Json
  createdAt    DateTime
  updatedAt    DateTime

  profile SandboxProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)

  @@map("agent_sandbox_configs")
}

model SandboxExecution {
  id             String                 @id
  agentId        String
  taskId         String?
  skillId        String?
  capability     String
  status         SandboxExecutionStatus
  mode           SandboxMode
  command        Json
  policySnapshot Json
  startedAt      DateTime?
  finishedAt     DateTime?
  durationMs     Int?
  exitCode       Int?
  resourceUsage  Json?
  errorMessage   String?
  stdout         String?
  stderr         String?

  artifacts SandboxArtifact[]
  approvals ApprovalRequest[]

  @@index([agentId])
  @@index([taskId])
  @@map("sandbox_executions")
}

model SandboxArtifact {
  id            String   @id
  executionId   String
  name          String
  path          String
  sizeBytes     Int
  sha256        String
  mimeType      String?
  retainedUntil DateTime?
  metadata      Json?

  execution SandboxExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId])
  @@map("sandbox_artifacts")
}

model ApprovalRequest {
  id               String          @id
  agentId          String
  taskId           String?
  executionId      String?
  reason           String
  requestedAction  Json
  status           ApprovalStatus
  approvedBy       String?
  approvedAt       DateTime?
  rejectedAt       DateTime?

  execution SandboxExecution? @relation(fields: [executionId], references: [id], onDelete: SetNull)

  @@index([agentId])
  @@index([taskId])
  @@index([executionId])
  @@map("approval_requests")
}

model MemoryEntry {
  id              String               @id
  type            MemoryType
  scopeType       MemoryScopeType
  scopeId         String
  agentId         String?
  taskId          String?
  sessionId       String?
  projectId       String?
  userId          String?
  teamId          String?
  title           String
  content         String
  summary         String?
  tags            Json
  source          String
  sourceEventId   String?
  createdAt       DateTime
  updatedAt       DateTime
  expiresAt       DateTime?
  isPinned        Boolean
  status          MemoryStatus
  importanceScore Float
  metadata        Json

  links            MemoryLink[]
  retrievalRecords MemoryRetrievalRecord[]

  @@index([type])
  @@index([scopeType, scopeId])
  @@index([agentId])
  @@index([taskId])
  @@index([sessionId])
  @@index([projectId])
  @@index([userId])
  @@index([teamId])
  @@index([status, isPinned])
  @@map("memory_entries")
}

model MemoryLink {
  id               String       @id
  memoryEntryId    String
  linkedEntityType  String
  linkedEntityId    String
  relationType      String
  createdAt         DateTime

  memoryEntry MemoryEntry @relation(fields: [memoryEntryId], references: [id], onDelete: Cascade)

  @@index([memoryEntryId])
  @@index([linkedEntityType, linkedEntityId])
  @@map("memory_links")
}

model MemoryRetrievalRecord {
  id                    String   @id
  taskId                String
  agentId               String?
  sessionId             String?
  memoryEntryId         String
  retrievalReason       String
  retrievalScore        Float
  usedInPromptAssembly   Boolean
  usedAt                DateTime
  createdAt             DateTime

  memoryEntry MemoryEntry @relation(fields: [memoryEntryId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([agentId])
  @@index([sessionId])
  @@index([memoryEntryId])
  @@map("memory_retrieval_records")
}

model MemoryPolicy {
  id                 String                @id
  memoryType         MemoryType
  scopeType          MemoryScopeType
  retentionMode      MemoryRetentionMode
  ttlDays            Int?
  maxEntries         Int?
  allowAutoPromotion Boolean
  allowManualPin     Boolean
  allowSemanticExtraction Boolean
  createdAt          DateTime
  updatedAt          DateTime

  @@unique([memoryType, scopeType])
  @@map("memory_policies")
}

model KnowledgeCollection {
  id          String              @id @default(uuid())
  name        String
  description String?
  scopeType   KnowledgeScopeType
  scopeId     String
  sourceType  KnowledgeSourceType
  status      KnowledgeStatus
  metadata    Json                @default("{}")
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  documents KnowledgeDocument[]

  @@map("knowledge_collections")
}

model KnowledgeDocument {
  id           String              @id @default(uuid())
  collectionId String
  title        String
  sourceType   KnowledgeSourceType
  sourcePath   String?
  mimeType     String?
  rawText      String?
  checksum     String?
  status       KnowledgeStatus
  metadata     Json                @default("{}")
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  collection KnowledgeCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  chunks     KnowledgeChunk[]

  @@index([collectionId])
  @@map("knowledge_documents")
}

model KnowledgeChunk {
  id            String            @id @default(uuid())
  documentId    String
  ordinal       Int
  content       String
  tokenEstimate Int?
  embeddingRef  String?
  metadata      Json              @default("{}")
  createdAt     DateTime          @default(now())

  document KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("knowledge_chunks")
}

model RetrievalRecord {
  id                  String   @id @default(uuid())
  taskId              String?
  sessionId           String?
  agentId             String?
  query               String
  filters             Json
  selectedChunkIds    String[]
  selectedDocumentIds String[]
  scoreSummary        Json
  durationMs          Int
  createdAt           DateTime @default(now())

  @@index([agentId])
  @@index([taskId])
  @@map("retrieval_records")
}

model AgentKnowledgePolicy {
  id                        String   @id @default(uuid())
  agentId                   String   @unique
  knowledgeEnabled          Boolean  @default(false)
  vaultReadEnabled          Boolean  @default(false)
  vaultWriteEnabled         Boolean  @default(false)
  writeMode                 String   @default("disabled")
  approvalRequired          Boolean  @default(true)
  allowedCollectionIds      String[]
  allowedPaths              String[]
  maxChunks                 Int      @default(5)
  maxContextTokens          Int      @default(2000)
  rerankEnabled             Boolean  @default(false)
  preferMemoryOverKnowledge Boolean  @default(true)
  preferKnowledgeOverMemory Boolean  @default(false)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@map("agent_knowledge_policies")
}

enum CommunicationChannel {
  web
  telegram
  discord
  cli
  mobile
  system
}

enum MessageRole {
  user
  assistant
  system
}

enum MessageContentType {
  text
  json
  event
  command
}

enum CommunicationSessionStatus {
  active
  idle
  closed
}

model CommunicationSession {
  id                String                     @id @default(uuid())
  channel           CommunicationChannel
  externalSessionId String?
  internalUserId    String?
  externalUserId    String?
  status            CommunicationSessionStatus @default(active)
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  lastMessageAt     DateTime?
  context           Json                       @default("{}")
  metadata          Json                       @default("{}")

  messages CommunicationMessage[]

  @@map("communication_sessions")
}

model CommunicationMessage {
  id        String             @id @default(uuid())
  sessionId String
  channel   CommunicationChannel
  role      MessageRole
  content   Json
  sender    Json
  metadata  Json               @default("{}")
  createdAt DateTime           @default(now())

  session CommunicationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("communication_messages")
}

enum Role {
  owner
  admin
  operator
  viewer
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  role         Role      @default(viewer)
  tenantId     String    @default("default")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  refreshTokens RefreshToken[]
  apiKeys       ApiKey[]

  @@index([tenantId])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model ApiKey {
  id         String    @id @default(uuid())
  name       String
  keyHash    String    @unique
  userId     String
  tenantId   String
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("api_keys")
}

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String
  userId     String?
  action     String
  resource   String
  resourceId String?
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([resource])
  @@map("audit_logs")
}
