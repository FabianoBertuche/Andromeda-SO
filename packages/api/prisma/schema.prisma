generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SandboxProfile {
  id          String      @id
  name        String
  description String
  version     Int
  isSystem    Boolean
  mode        String
  riskLevel   String
  config      Json
  tenantId    String      @default("default")
  createdAt   DateTime
  updatedAt   DateTime
  deletedAt   DateTime?
  archivedAt  DateTime?

  agentConfigs AgentSandboxConfig[]

  @@index([tenantId])
  @@index([deletedAt])
  @@map("sandbox_profiles")
}

model AgentSandboxConfig {
  agentId      String   @id
  enabled      Boolean
  profileId    String?
  overrides    Json
  enforcement  Json
  tenantId     String   @default("default")
  createdAt    DateTime
  updatedAt    DateTime
  deletedAt    DateTime?
  archivedAt   DateTime?

  profile SandboxProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([deletedAt])
  @@map("agent_sandbox_configs")
}

model SandboxExecution {
  id             String                 @id
  agentId        String
  taskId         String?
  skillId        String?
  capability     String
  status         String
  mode           String
  command        Json
  policySnapshot Json
  startedAt      DateTime?
  finishedAt     DateTime?
  durationMs     Int?
  exitCode       Int?
  resourceUsage  Json?
  errorMessage   String?
  stdout         String?
  stderr         String?

  tenantId       String                 @default("default")
  deletedAt      DateTime?
  archivedAt     DateTime?

  artifacts SandboxArtifact[]
  approvals ApprovalRequest[]

  @@index([tenantId])
  @@index([agentId])
  @@index([taskId])
  @@index([deletedAt])
  @@map("sandbox_executions")
}

model SandboxArtifact {
  id            String   @id
  executionId   String
  name          String
  path          String
  sizeBytes     Int
  sha256        String
  mimeType      String?
  retainedUntil DateTime?
  metadata      Json?

  execution SandboxExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId])
  @@map("sandbox_artifacts")
}

model ApprovalRequest {
  id               String          @id
  agentId          String
  taskId           String?
  executionId      String?
  reason           String
  requestedAction  Json
  status           String
  approvedBy       String?
  approvedAt       DateTime?
  rejectedAt       DateTime?

  execution SandboxExecution? @relation(fields: [executionId], references: [id], onDelete: SetNull)

  @@index([agentId])
  @@index([taskId])
  @@index([executionId])
  @@map("approval_requests")
}

model MemoryEntry {
  id              String               @id
  type            String
  scopeType       String
  scopeId         String
  agentId         String?
  taskId          String?
  sessionId       String?
  projectId       String?
  userId          String?
  teamId          String?
  title           String
  content         String
  summary         String?
  tags            Json
  source          String
  sourceEventId   String?
  createdAt       DateTime
  updatedAt       DateTime
  deletedAt       DateTime?
  archivedAt      DateTime?
  expiresAt       DateTime?
  isPinned        Boolean
  status          String
  importanceScore Float
  tenantId        String               @default("default")
  metadata        Json

  links            MemoryLink[]
  retrievalRecords MemoryRetrievalRecord[]

  @@index([tenantId])
  @@index([type])
  @@index([scopeType, scopeId])
  @@index([agentId])
  @@index([taskId])
  @@index([sessionId])
  @@index([projectId])
  @@index([userId])
  @@index([teamId])
  @@index([status, isPinned])
  @@index([deletedAt])
  @@map("memory_entries")
}

model MemoryLink {
  id               String       @id
  memoryEntryId    String
  linkedEntityType  String
  linkedEntityId    String
  relationType      String
  tenantId          String       @default("default")
  createdAt         DateTime

  memoryEntry MemoryEntry @relation(fields: [memoryEntryId], references: [id], onDelete: Cascade)

  @@index([memoryEntryId])
  @@index([tenantId])
  @@index([linkedEntityType, linkedEntityId])
  @@map("memory_links")
}

model MemoryRetrievalRecord {
  id                    String   @id
  taskId                String
  agentId               String?
  sessionId             String?
  memoryEntryId         String
  retrievalReason       String
  retrievalScore        Float
  usedInPromptAssembly   Boolean
  usedAt                DateTime
  tenantId              String   @default("default")
  createdAt             DateTime

  memoryEntry MemoryEntry @relation(fields: [memoryEntryId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([tenantId])
  @@index([agentId])
  @@index([sessionId])
  @@index([memoryEntryId])
  @@map("memory_retrieval_records")
}

model MemoryPolicy {
  id                 String                @id
  memoryType         String
  scopeType          String
  retentionMode      String
  ttlDays            Int?
  maxEntries         Int?
  allowAutoPromotion Boolean
  allowManualPin     Boolean
  allowSemanticExtraction Boolean
  tenantId           String                @default("default")
  createdAt          DateTime
  updatedAt          DateTime
  deletedAt          DateTime?
  archivedAt         DateTime?

  @@unique([tenantId, memoryType, scopeType])
  @@map("memory_policies")
}

model KnowledgeCollection {
  id          String              @id @default(uuid())
  name        String
  description String?
  scopeType   String
  scopeId     String
  sourceType  String
  status      String
  metadata    Json                @default("{}")
  tenantId    String              @default("default")
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  deletedAt   DateTime?
  archivedAt  DateTime?

  documents KnowledgeDocument[]

  @@index([tenantId])
  @@index([deletedAt])
  @@map("knowledge_collections")
}

model KnowledgeDocument {
  id           String              @id @default(uuid())
  collectionId String
  title        String
  sourceType   String
  sourcePath   String?
  mimeType     String?
  rawText      String?
  checksum     String?
  status       String
  metadata     Json                @default("{}")
  tenantId     String              @default("default")
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  deletedAt    DateTime?
  archivedAt   DateTime?

  collection KnowledgeCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  chunks     KnowledgeChunk[]

  @@index([collectionId])
  @@index([deletedAt])
  @@map("knowledge_documents")
}

model KnowledgeChunk {
  id            String            @id @default(uuid())
  documentId    String
  ordinal       Int
  content       String
  tokenEstimate Int?
  embeddingRef  String?
  metadata      Json              @default("{}")
  tenantId      String            @default("default")
  createdAt     DateTime          @default(now())
  deletedAt     DateTime?
  archivedAt    DateTime?

  document KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([deletedAt])
  @@map("knowledge_chunks")
}

model RetrievalRecord {
  id                  String   @id @default(uuid())
  taskId              String?
  sessionId           String?
  agentId             String?
  query               String
  filters             Json
  selectedChunkIds    String
  selectedDocumentIds String
  scoreSummary        Json
  durationMs          Int
  tenantId            String   @default("default")
  createdAt           DateTime @default(now())

  @@index([tenantId])

  @@index([agentId])
  @@index([taskId])
  @@map("retrieval_records")
}

model AgentKnowledgePolicy {
  id                        String   @id @default(uuid())
  agentId                   String   @unique
  knowledgeEnabled          Boolean  @default(false)
  vaultReadEnabled          Boolean  @default(false)
  vaultWriteEnabled         Boolean  @default(false)
  writeMode                 String   @default("disabled")
  approvalRequired          Boolean  @default(true)
  allowedCollectionIds      String
  allowedPaths              String
  maxChunks                 Int      @default(5)
  maxContextTokens          Int      @default(2000)
  rerankEnabled             Boolean  @default(false)
  preferMemoryOverKnowledge Boolean  @default(true)
  preferKnowledgeOverMemory Boolean  @default(false)
  tenantId                  String   @default("default")
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@index([tenantId])
  @@map("agent_knowledge_policies")
}

model CommunicationSession {
  id                String                     @id @default(uuid())
  channel           String
  externalSessionId String?
  internalUserId    String?
  externalUserId    String?
  status            String                     @default("active")
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  deletedAt         DateTime?
  archivedAt        DateTime?
  lastMessageAt     DateTime?
  context           Json                       @default("{}")
  metadata          Json                       @default("{}")

  tenantId          String                     @default("default")

  messages CommunicationMessage[]

  @@index([tenantId])
  @@index([deletedAt])
  @@map("communication_sessions")
}

model CommunicationMessage {
  id        String             @id @default(uuid())
  sessionId String
  channel   String
  role      String
  content   Json
  sender    Json
  metadata  Json               @default("{}")
  tenantId  String             @default("default")
  createdAt DateTime           @default(now())
  deletedAt DateTime?
  archivedAt DateTime?

  @@index([tenantId])
  @@index([deletedAt])

  session CommunicationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("communication_messages")
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  role         String    @default("viewer")
  tenantId     String    @default("default")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  refreshTokens RefreshToken[]
  apiKeys       ApiKey[]

  @@index([tenantId])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model ApiKey {
  id         String    @id @default(uuid())
  name       String
  keyHash    String    @unique
  userId     String
  tenantId   String
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("api_keys")
}

model AgentBudgetPolicy {
  id                 String   @id @default(cuid())
  tenantId           String   @default("default")
  agentId            String
  dailyLimitUsd      Decimal  @db.Decimal(12, 4)
  monthlyLimitUsd    Decimal  @db.Decimal(12, 4)
  dailySpentUsd      Decimal  @default(0) @db.Decimal(12, 4)
  monthlySpentUsd    Decimal  @default(0) @db.Decimal(12, 4)
  currency           String   @default("USD")
  alertsEnabled      Boolean  @default(true)
  lastDailyResetAt   DateTime?
  lastMonthlyResetAt DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  deletedAt          DateTime?

  @@unique([tenantId, agentId])
  @@index([tenantId])
  @@index([tenantId, agentId])
  @@index([tenantId, deletedAt])
  @@map("agent_budget_policies")
}

model AgentVersion {
  id                        String   @id @default(cuid())
  tenantId                  String   @default("default")
  agentId                   String
  versionNumber             Int
  sourceVersionLabel        String?
  snapshot                  Json
  changeSummary             String
  restoredFromVersionNumber Int?
  createdBy                 String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  deletedAt                 DateTime?

  @@unique([tenantId, agentId, versionNumber])
  @@index([tenantId])
  @@index([tenantId, agentId])
  @@index([tenantId, agentId, createdAt])
  @@index([tenantId, deletedAt])
  @@map("agent_versions")
}

model TaskFeedback {
  id          String   @id @default(cuid())
  tenantId    String   @default("default")
  taskId      String
  agentId     String
  userId      String
  rating      Int
  comment     String?
  metadata    Json?
  submittedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@unique([tenantId, taskId, userId])
  @@index([tenantId])
  @@index([tenantId, agentId])
  @@index([tenantId, taskId])
  @@index([tenantId, submittedAt])
  @@index([tenantId, deletedAt])
  @@map("task_feedback")
}

model AgentPerformanceRecord {
  id                  String   @id @default(cuid())
  tenantId            String   @default("default")
  agentId             String
  periodType          String
  periodStart         DateTime
  periodEnd           DateTime
  tasksTotal          Int      @default(0)
  tasksSucceeded      Int      @default(0)
  tasksFailed         Int      @default(0)
  successRate         Decimal  @default(0) @db.Decimal(5, 4)
  avgConformance      Decimal? @db.Decimal(5, 4)
  feedbackScore       Decimal? @db.Decimal(5, 4)
  avgLatencyMs        Int?
  totalTokensUsed     Int      @default(0)
  totalCostUsd        Decimal  @default(0) @db.Decimal(12, 4)
  reputationScores    Json?
  reputationUpdatedAt DateTime?
  metricsSnapshot     Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  deletedAt           DateTime?

  @@unique([tenantId, agentId, periodType, periodStart, periodEnd])
  @@index([tenantId])
  @@index([tenantId, agentId])
  @@index([tenantId, periodType, periodStart])
  @@index([tenantId, deletedAt])
  @@map("agent_performance_records")
}

model PlaybookSuggestion {
  id              String   @id @default(cuid())
  tenantId        String   @default("default")
  agentId         String
  title           String
  summary         String
  proposedChange  Json
  confidence      Decimal  @db.Decimal(4, 3)
  status          String
  sourceEpisodeIds Json?
  analysisPayload Json?
  reviewedBy      String?
  reviewedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  @@index([tenantId])
  @@index([tenantId, agentId])
  @@index([tenantId, status])
  @@index([tenantId, confidence])
  @@index([tenantId, deletedAt])
  @@map("playbook_suggestions")
}

model AgentExecutionLedger {
  id                   String   @id @default(cuid())
  tenantId             String   @default("default")
  taskId               String
  agentId              String
  sessionId            String?
  capability           String?
  status               String
  model                String?
  provider             String?
  promptTokens         Int?
  completionTokens     Int?
  totalTokens          Int?
  latencyMs            Int?
  costUsd              Decimal? @db.Decimal(12, 4)
  conformanceScore     Decimal? @db.Decimal(5, 4)
  feedbackRating       Int?
  executionStartedAt   DateTime?
  executionCompletedAt DateTime?
  resultSnapshot       Json?
  metadata             Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  deletedAt            DateTime?

  @@unique([tenantId, taskId])
  @@index([tenantId])
  @@index([tenantId, agentId])
  @@index([tenantId, executionCompletedAt])
  @@index([tenantId, status])
  @@index([tenantId, deletedAt])
  @@map("agent_execution_ledger")
}

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String
  userId     String?
  action     String
  resource   String
  resourceId String?
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([resource])
  @@map("audit_logs")
}
